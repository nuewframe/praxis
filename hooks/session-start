#!/usr/bin/env bash
# SessionStart hook for the praxis plugin.
#
# Reads skills/using-praxis/SKILL.md and emits it as session context in the
# format expected by the host harness (Claude Code, Cursor, Copilot CLI).
#
# The matcher (hooks.json) fires on startup|clear|compact by design: on
# harnesses without applyTo-scoped instructions (e.g. Claude Code), this dump is
# the ONLY always-on surface for the guardrail summary, so it must be
# re-asserted after a /clear or a context compaction or the guardrails silently
# fall out of the model's context. The cost of re-injecting is the deliberate
# price of keeping the guardrails always-on there.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

bootstrap_content=$(cat "${PLUGIN_ROOT}/skills/using-praxis/SKILL.md" 2>&1 || echo "Error reading using-praxis skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

bootstrap_escaped=$(escape_for_json "$bootstrap_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have praxis loaded.\n\n**Below is the full content of your 'praxis:using-praxis' skill — your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${bootstrap_escaped}\n</EXTREMELY_IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
