#!/usr/bin/env bash
# Pre-push hook for {{project.name}}.
# Generated by the `provision-project-overlay` plugin skill.
#
# Runs the full verification entry point before a push so the script-enforced
# gates (format, lint, type-check, every guardrail check, tests) fail closed
# even without CI. Pre-commit is fast (no tests); pre-push is the fuller gate.
#
# Install:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-push
#
# Skip in an emergency with:  git push --no-verify   (records nothing — use sparingly)

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if [[ -x scripts/verify.sh ]]; then
  echo "pre-push: running scripts/verify.sh ..."
  if ! bash scripts/verify.sh; then
    echo "✗ pre-push: verify failed — push blocked. Fix, or 'git push --no-verify' to override." >&2
    exit 1
  fi
else
  echo "pre-push: scripts/verify.sh not found — skipping (run bootstrap/provision to generate it)." >&2
fi

exit 0
