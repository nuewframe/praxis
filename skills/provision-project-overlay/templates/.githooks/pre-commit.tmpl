#!/usr/bin/env bash
# Pre-commit hook for {{project.name}}.
# Generated by the `provision-project-overlay` plugin skill.
#
# Install:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-commit
#
# Or wire into pre-commit (https://pre-commit.com) via .pre-commit-config.yaml.

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

fail=0

# ---------------------------------------------------------------------------
# Anti-dumping check (capability-driven layout enforcement)
# ---------------------------------------------------------------------------
if [[ -x plugin/scripts/check-anti-dumping.sh ]]; then
  if ! bash plugin/scripts/check-anti-dumping.sh; then
    echo "✗ anti-dumping: FAILED — capability-driven layout violated"
    fail=1
  fi
else
  # Fallback: inline anti-dumping check on staged files
  forbidden_pattern='(^|/)(utils|helpers|common|shared|misc|lib)(\.[^/]+|/)'
  staged=$(git diff --cached --name-only --diff-filter=A)
  if echo "$staged" | grep -E "$forbidden_pattern" >/dev/null; then
    echo "✗ anti-dumping: FAILED — staged files contain forbidden dumping-ground names:"
    echo "$staged" | grep -E "$forbidden_pattern" | sed 's/^/    /'
    fail=1
  fi
fi

# ---------------------------------------------------------------------------
# Lint
# ---------------------------------------------------------------------------
if ! {{quality_gates.lint}}; then
  echo "✗ lint: FAILED"
  fail=1
fi

# ---------------------------------------------------------------------------
# Format check (do not auto-format in a hook; report only)
# ---------------------------------------------------------------------------
if ! {{quality_gates.format}}; then
  echo "✗ format: FAILED — run the formatter and re-stage"
  fail=1
fi

# ---------------------------------------------------------------------------
# Type check
# ---------------------------------------------------------------------------
if ! {{quality_gates.type_check}}; then
  echo "✗ type-check: FAILED"
  fail=1
fi

# ---------------------------------------------------------------------------
# Tests are NOT run in pre-commit (too slow). Run before push instead.
# ---------------------------------------------------------------------------

if [[ $fail -ne 0 ]]; then
  echo
  echo "Pre-commit blocked. Fix the failures above and re-stage."
  exit 1
fi

echo "✓ pre-commit passed"
